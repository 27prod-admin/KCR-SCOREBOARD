<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kings League Scoreboard Pro - Mobile Sync</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Rajdhani:wght@500;700&display=swap" rel="stylesheet">
    <style>
        :root { --kl-orange: #f59e0b; --kl-azure: #00ffff; }
        body { background-color: #00FF00; font-family: 'Rajdhani', sans-serif; margin: 0; color: white; width: 100%; }
        
        .view-section { display: none !important; }
        body[data-view="all"] .view-section { display: flex !important; flex-direction: column; min-height: 2800px; }
        body[data-view="scoreboard"] { height: 100vh; overflow: hidden !important; }
        body[data-view="scoreboard"] #scoreboard-area { display: flex !important; height: 100vh; width: 1920px; }
        body[data-view="control"] { background-color: #0a0a0a; min-height: 100vh; overflow-y: auto; }
        body[data-view="control"] #control-panel-area { display: flex !important; margin-top: 0 !important; width: 100%; padding: 10px; }

        .kl-font { font-family: 'Orbitron', sans-serif; font-variant-numeric: tabular-nums; }
        .glass-panel { background: rgba(15, 15, 15, 0.98); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .score-box { background: linear-gradient(180deg, #1a1a1a 0%, #000 100%); border-bottom: 5px solid var(--kl-orange); position: relative; overflow: hidden; width: 495px; flex-shrink: 0; }
        
        .status-indicators { position: absolute; top: 0; bottom: 0; width: 11px; display: flex; flex-direction: column; transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); z-index: 20; }
        .indicator-left { left: 0; border-right: 1px solid rgba(255,255,255,0.1); }
        .indicator-right { right: 0; border-left: 1px solid rgba(255,255,255,0.1); }
        .bar-weapon { background: white; flex: 1; box-shadow: 0 0 15px white; }
        .bar-presidential { background: var(--kl-azure); flex: 1; box-shadow: 0 0 15px var(--kl-azure); }
        .indicator-off { opacity: 0; transform: scaleX(0); }

        .weapon-appendage { font-weight: 900; text-transform: uppercase; display: flex; align-items: center; justify-content: center; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); height: 99px; width: 288px; z-index: 5; overflow: hidden; flex-shrink: 0; }
        .weapon-orange { background: var(--kl-orange); color: black; }
        .weapon-white { background: #ffffff; color: #000; }
        .weapon-azure { background: var(--kl-azure); color: #000; }
        .active-weapon-pulse { animation: weapon-pulse 2s infinite; }
        @keyframes weapon-pulse { 0%, 100% { filter: brightness(1); } 50% { filter: brightness(1.3); } }

        .weapon-btn { background: #222; border: 2px solid #444; padding: 12px 8px; border-radius: 10px; font-size: 13px; font-weight: 800; text-transform: uppercase; color: #eee; }
        .weapon-btn:active { transform: scale(0.95); background: var(--kl-orange); color: black; }
        .presidential { border-color: var(--kl-azure); color: var(--kl-azure); }
    </style>
</head>
<body data-view="all">

    <div id="scoreboard-area" class="view-section w-full items-center pt-16">
        <div id="scoreboard-display" class="relative flex flex-col items-center space-y-8">
            <div class="flex items-start justify-center">
                <div id="penalty-timers-A" class="flex flex-col space-y-4 items-end pt-4 mr-10 min-w-[225px]"></div>
                <div class="flex items-center">
                    <div id="display-weapon-A" class="hidden weapon-appendage appendage-left px-6 active-weapon-pulse">
                        <div class="flex flex-col items-end leading-tight text-black">
                            <div id="weapon-text-A" class="text-right uppercase italic">
                                <span class="text-[28px] font-black block leading-none">Arma</span>
                                <span class="text-[16px] font-bold opacity-70 block -mt-1">Player</span>
                            </div>
                            <span id="weapon-timer-A" class="text-3xl kl-font hidden font-black">00:00</span>
                        </div>
                        <span class="ml-4 text-3xl font-black">◈</span>
                    </div>
                    <div class="flex items-center justify-center kl-font shadow-2xl relative z-10">
                        <div class="score-box px-10 py-5 flex items-center space-x-6 rounded-l-2xl border-r border-gray-800">
                            <div class="status-indicators indicator-left">
                                <div id="ind-weapon-A" class="bar-weapon"></div>
                                <div id="ind-pres-A" class="bar-presidential"></div>
                            </div>
                            <img id="display-logoA" src="" class="w-[54px] h-[54px] object-contain ml-2">
                            <span id="display-teamA-name" class="text-3xl font-bold uppercase tracking-tighter flex-1 text-right truncate">TEAM A</span>
                            <span id="display-teamA-score" class="text-6xl font-black text-orange-500 w-[60px] text-center flex-shrink-0">0</span>
                        </div>
                        <div class="bg-orange-500 text-black px-8 py-3 flex flex-col items-center justify-center w-[198px] min-w-[198px] flex-shrink-0 border-b-8 border-orange-700">
                            <span id="display-period" class="text-xs font-bold uppercase tracking-widest text-black/60">1° TEMPO</span>
                            <span id="display-timer" class="text-5xl font-black leading-none kl-font">00:00</span>
                        </div>
                        <div class="score-box px-10 py-5 flex items-center space-x-6 rounded-r-2xl border-l border-gray-800">
                            <span id="display-teamB-score" class="text-6xl font-black text-orange-500 w-[60px] text-center flex-shrink-0">0</span>
                            <span id="display-teamB-name" class="text-3xl font-bold uppercase tracking-tighter flex-1 text-left truncate">TEAM B</span>
                            <img id="display-logoB" src="" class="w-[54px] h-[54px] object-contain mr-2">
                            <div class="status-indicators indicator-right">
                                <div id="ind-weapon-B" class="bar-weapon"></div>
                                <div id="ind-pres-B" class="bar-presidential"></div>
                            </div>
                        </div>
                    </div>
                    <div id="display-weapon-B" class="hidden weapon-appendage appendage-right px-6 active-weapon-pulse">
                        <span class="mr-4 text-3xl font-black">◈</span>
                        <div class="flex flex-col items-start leading-tight text-black">
                            <div id="weapon-text-B" class="text-left uppercase italic">
                                <span class="text-[28px] font-black block leading-none">Arma</span>
                                <span class="text-[16px] font-bold opacity-70 block -mt-1">Player</span>
                            </div>
                            <span id="weapon-timer-B" class="text-3xl kl-font hidden font-black">00:00</span>
                        </div>
                    </div>
                </div>
                <div id="penalty-timers-B" class="flex flex-col space-y-4 items-start pt-4 ml-10 min-w-[225px]"></div>
            </div>
            <div id="dice-container" class="hidden flex flex-col items-center pt-4">
                <div id="dice-visual" class="w-28 h-28 bg-white text-black text-6xl font-black rounded-3xl flex items-center justify-center shadow-xl border-4 border-orange-500">?</div>
            </div>
        </div>
    </div>

    <div id="control-panel-area" class="view-section flex-col items-center w-full pb-20">
        <div class="glass-panel p-4 md:p-10 rounded-xl md:rounded-[4rem] w-full max-w-[1600px] border-t-8 border-orange-500">
            <div class="mb-8 border-b border-white/10 pb-4 flex justify-between items-center">
                <h2 class="text-2xl md:text-5xl font-black text-orange-500 uppercase italic">Regia Kings</h2>
                <button onclick="copyRemoteLink()" class="bg-white/10 px-4 py-2 rounded text-[10px] uppercase font-bold">Link Telefono</button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="space-y-4 bg-white/5 p-4 rounded-2xl">
                    <input type="text" id="input-teamA" placeholder="Team Casa" oninput="updateNames()" class="w-full bg-black border-2 border-gray-700 p-3 rounded text-xl font-bold">
                    <input type="text" id="input-starA" placeholder="Star Player A" oninput="updateNames()" class="w-full bg-black border border-orange-900 p-2 rounded text-sm">
                    <div class="flex space-x-2">
                        <button onclick="changeScore('A', -1)" class="bg-gray-800 p-4 rounded flex-1">-1</button>
                        <button onclick="changeScore('A', 1)" class="bg-orange-600 p-4 rounded flex-[2] font-black uppercase">Goal A</button>
                    </div>
                    <hr class="opacity-10">
                    <input type="text" id="input-teamB" placeholder="Team Ospiti" oninput="updateNames()" class="w-full bg-black border-2 border-gray-700 p-3 rounded text-xl font-bold">
                    <input type="text" id="input-starB" placeholder="Star Player B" oninput="updateNames()" class="w-full bg-black border border-orange-900 p-2 rounded text-sm">
                    <div class="flex space-x-2">
                        <button onclick="changeScore('B', -1)" class="bg-gray-800 p-4 rounded flex-1">-1</button>
                        <button onclick="changeScore('B', 1)" class="bg-orange-600 p-4 rounded flex-[2] font-black uppercase">Goal B</button>
                    </div>
                </div>

                <div class="space-y-4">
                    <button onclick="toggleTimer()" id="btn-timer" class="bg-green-600 w-full p-8 rounded-2xl font-black text-3xl uppercase border-b-8 border-green-800">Avvia</button>
                    <div class="flex gap-2">
                        <button onclick="resetTimer()" class="bg-gray-800 p-4 rounded flex-1 font-bold">RESET</button>
                        <button onclick="setPeriod()" class="bg-gray-800 p-4 rounded flex-1 font-bold">TEMPO</button>
                    </div>
                    <button onclick="rollDice()" class="bg-indigo-600 w-full p-6 rounded-2xl font-black text-xl uppercase border-b-8 border-indigo-800">Dado Lega</button>
                </div>

                <div class="space-y-4">
                    <div class="bg-white/5 p-4 rounded-xl">
                        <p class="text-[10px] text-orange-400 font-bold mb-2">ARMI CASA</p>
                        <div class="grid grid-cols-2 gap-2">
                            <button onclick="activateWeaponDirect('A', 'GOL DOPPIO')" class="weapon-btn">Gol Doppio</button>
                            <button onclick="activateWeaponDirect('A', 'SOSPENSIONE')" class="weapon-btn">Sospensione</button>
                            <button onclick="activateWeaponDirect('A', 'STAR PLAYER')" class="weapon-btn">Star Player</button>
                            <button onclick="activatePresidential('A')" class="weapon-btn presidential">Presidenziale</button>
                        </div>
                    </div>
                    <div class="bg-white/5 p-4 rounded-xl">
                        <p class="text-[10px] text-orange-400 font-bold mb-2">ARMI OSPITI</p>
                        <div class="grid grid-cols-2 gap-2">
                            <button onclick="activateWeaponDirect('B', 'GOL DOPPIO')" class="weapon-btn">Gol Doppio</button>
                            <button onclick="activateWeaponDirect('B', 'SOSPENSIONE')" class="weapon-btn">Sospensione</button>
                            <button onclick="activateWeaponDirect('B', 'STAR PLAYER')" class="weapon-btn">Star Player</button>
                            <button onclick="activatePresidential('B')" class="weapon-btn presidential">Presidenziale</button>
                        </div>
                    </div>
                    <button onclick="resetAllEvents()" class="w-full bg-red-900/60 p-4 rounded-xl font-bold uppercase text-xs">Reset Totale Eventi</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // SISTEMA DI SINCRONIZZAZIONE STORAGE
        const STORAGE_KEY = 'kings_league_state_v2';
        
        let state = {
            teamA: { name: "TEAM A", score: 0, logo: "", starPlayer: "", hasWeapon: true, hasPresidential: true },
            teamB: { name: "TEAM B", score: 0, logo: "", starPlayer: "", hasWeapon: true, hasPresidential: true },
            timer: 0, isRunning: false, period: "1° TEMPO", penalties: [],
            activeWeapons: {
                A: { name: "", timeLeft: 0, hasTimer: false, colorClass: 'weapon-orange' },
                B: { name: "", timeLeft: 0, hasTimer: false, colorClass: 'weapon-orange' }
            }
        };

        const urlParams = new URLSearchParams(window.location.search);
        const viewMode = urlParams.get('view') || 'all';
        document.body.setAttribute('data-view', viewMode);

        function saveState() {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
            updateDisplay();
        }

        window.addEventListener('storage', (e) => {
            if (e.key === STORAGE_KEY) {
                state = JSON.parse(e.newValue);
                updateDisplay();
            }
        });

        // Caricamento iniziale
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved) state = JSON.parse(saved);

        let timerInterval;

        function updateDisplay() {
            // Testi Scoreboard
            const ids = ['teamA-name', 'teamB-name', 'teamA-score', 'teamB-score', 'period', 'timer'];
            ids.forEach(id => {
                const el = document.getElementById('display-' + id);
                if (el) {
                    if (id === 'timer') {
                        const m = Math.floor(state.timer / 60);
                        const s = state.timer % 60;
                        el.innerText = `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
                    } else if (id.includes('score')) el.innerText = state[id.includes('teamA') ? 'teamA' : 'teamB'].score;
                    else if (id === 'period') el.innerText = state.period;
                    else el.innerText = state[id.includes('teamA') ? 'teamA' : 'teamB'].name;
                }
            });

            // Bordi Luci
            ['A', 'B'].forEach(t => {
                const w = document.getElementById(`ind-weapon-${t}`);
                const p = document.getElementById(`ind-pres-${t}`);
                if (w) state[`team${t}`].hasWeapon ? w.classList.remove('indicator-off') : w.classList.add('indicator-off');
                if (p) state[`team${t}`].hasPresidential ? p.classList.remove('indicator-off') : p.classList.add('indicator-off');
                updateWeaponDisplay(t);
            });

            // Pulsante Regia
            const btn = document.getElementById('btn-timer');
            if (btn) {
                btn.innerText = state.isRunning ? "PAUSA" : "AVVIA";
                btn.className = state.isRunning ? "bg-red-600 w-full p-8 rounded-2xl font-black text-3xl uppercase border-b-8 border-red-800" : "bg-green-600 w-full p-8 rounded-2xl font-black text-3xl uppercase border-b-8 border-green-800";
            }
        }

        function updateWeaponDisplay(team) {
            const w = state.activeWeapons[team];
            const div = document.getElementById(`display-weapon-${team}`);
            const text = document.getElementById(`weapon-text-${team}`);
            const timerEl = document.getElementById(`weapon-timer-${team}`);
            if (!div) return;

            if (w.timeLeft > 0) {
                div.classList.remove('hidden');
                div.className = `weapon-appendage appendage-${team === 'A' ? 'left' : 'right'} px-6 active-weapon-pulse ${w.colorClass}`;
                if (w.name === 'STAR PLAYER') {
                    text.innerHTML = `<span class="text-[28px] font-black block leading-none">STAR PLAYER</span><span class="text-[16px] font-bold opacity-70 block">${state[`team${team}`].starPlayer || ''}</span>`;
                } else {
                    text.innerHTML = `<span class="text-[28px] font-black block leading-none">${w.name}</span>`;
                }
                if (w.hasTimer) {
                    timerEl.classList.remove('hidden');
                    const m = Math.floor(w.timeLeft / 60);
                    const s = w.timeLeft % 60;
                    timerEl.innerText = `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
                } else timerEl.classList.add('hidden');
            } else div.classList.add('hidden');
        }

        function toggleTimer() {
            state.isRunning = !state.isRunning;
            if (state.isRunning) {
                timerInterval = setInterval(() => {
                    state.timer++;
                    ['A', 'B'].forEach(t => { if(state.activeWeapons[t].timeLeft > 0) state.activeWeapons[t].timeLeft--; });
                    saveState();
                }, 1000);
            } else clearInterval(timerInterval);
            saveState();
        }

        function changeScore(t, v) { state[`team${t}`].score = Math.max(0, state[`team${t}`].score + v); saveState(); }
        function updateNames() {
            state.teamA.name = document.getElementById('input-teamA').value || "TEAM A";
            state.teamB.name = document.getElementById('input-teamB').value || "TEAM B";
            state.teamA.starPlayer = document.getElementById('input-starA').value;
            state.teamB.starPlayer = document.getElementById('input-starB').value;
            saveState();
        }
        function setPeriod() { state.period = state.period.includes('1') ? '2° TEMPO' : '1° TEMPO'; saveState(); }
        function resetTimer() { state.timer = 0; saveState(); }

        function activateWeaponDirect(team, name) {
            if (state.activeWeapons[team].name === name && state.activeWeapons[team].timeLeft > 0) {
                state.activeWeapons[team].timeLeft = 0;
            } else {
                let dur = 60, hasT = false, col = 'weapon-orange';
                if (name === 'GOL DOPPIO') { dur = 120; hasT = true; col = 'weapon-white'; }
                if (name === 'SOSPENSIONE') { dur = 240; hasT = true; col = 'weapon-white'; }
                state[`team${team}`].hasWeapon = false;
                state.activeWeapons[team] = { name: name, timeLeft: dur, hasTimer: hasT, colorClass: col };
            }
            saveState();
        }

        function activatePresidential(team) {
            if (state.activeWeapons[team].name === "RIGORE PRES." && state.activeWeapons[team].timeLeft > 0) {
                state.activeWeapons[team].timeLeft = 0;
            } else {
                state[`team${team}`].hasPresidential = false;
                state.activeWeapons[team] = { name: "RIGORE PRES.", timeLeft: 60, hasTimer: false, colorClass: 'weapon-azure' };
            }
            saveState();
        }

        function resetAllEvents() {
            state.teamA.hasWeapon = state.teamA.hasPresidential = state.teamB.hasWeapon = state.teamB.hasPresidential = true;
            state.activeWeapons.A.timeLeft = state.activeWeapons.B.timeLeft = 0;
            saveState();
        }

        function rollDice() {
            // Dado locale, sync via storage
            const options = ["1vs1", "2vs2", "3vs3", "4vs4", "5vs5", "6vs6"];
            const res = options[Math.floor(Math.random() * options.length)];
            // Semplificazione: il dado lo gestiamo solo visivamente per ora
            const container = document.getElementById('dice-container');
            const visual = document.getElementById('dice-visual');
            container.classList.remove('hidden');
            visual.innerText = res;
            setTimeout(() => container.classList.add('hidden'), 5000);
        }

        function copyRemoteLink() {
            const url = window.location.href.split('?')[0] + '?view=control';
            navigator.clipboard.writeText(url);
            alert("Link regia copiato! Inviatelo al telefono.");
        }

        if (state.isRunning) toggleTimer(); // Riprende se era attivo
        updateDisplay();
    </script>
</body>
</html>
